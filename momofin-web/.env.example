# Variables d'environnement MoMo Fin Web
# Sur Railway, ces variables sont à définir dans Project Settings → Variables

# Fourni automatiquement par le plugin PostgreSQL de Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Mot de passe d'accès au tableau de bord web (laisser vide pour libre accès en dev)
ADMIN_PASSWORD=changemoi

# Optionnel : token de device par défaut (créé au premier démarrage si la table devices est vide)
DEFAULT_DEVICE_TOKEN=

# Pour activer les boutons de téléchargement APK sur la page /telecharger
# Format : "votre-user/nom-du-depot" (sans https://github.com/)
GITHUB_REPO=votre-user/momofin
# Tag de la release contenant les APK. "latest" suit la dernière release publiée.
GITHUB_RELEASE_TAG=latest

# URL publique de l'app (pour le bouton "Version web") — optionnel, déduite automatiquement sinon
PUBLIC_URL=
