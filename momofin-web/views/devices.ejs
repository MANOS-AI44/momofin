<%- include('_layout_head', { pageTitle: 'Mes Appareils — MoMo Fin', activeNav: 'devices', user: user }) %>

<h1>📱 Mes Appareils</h1>
<p class="subtitle">Créez un code par boutique. Chaque code permet à un téléphone de se connecter à votre compte.</p>

<section class="panel">
    <h3>Créer un nouvel appareil</h3>
    <form method="POST" action="/devices" class="filter-row">
        <input type="text" name="label" placeholder="Nom (ex. Boutique 1, Boutique 2…)" required style="flex:1;min-width:240px;" />
        <button class="btn success" type="submit">+ Créer un code</button>
    </form>
</section>

<section class="panel">
    <h2>Appareils inscrits (<%= devices.length %>)</h2>
    <table>
        <thead>
            <tr><th>Nom</th><th>Code court (à dicter)</th><th>Token long</th><th>Créé le</th><th></th></tr>
        </thead>
        <tbody>
            <% devices.forEach(function(d) { %>
                <tr>
                    <td><strong><%= d.label || '—' %></strong></td>
                    <td><strong style="font-size:18px; color:#1565C0; letter-spacing:2px;"><%= d.code || '—' %></strong></td>
                    <td><code style="font-size:10px;"><%= d.token.substring(0, 16) %>…</code></td>
                    <td><%= new Date(d.created_at).toLocaleString('fr-FR') %></td>
                    <td style="white-space:nowrap;">
                        <a href="/devices/<%= d.token %>/transactions" class="btn primary" style="padding:6px 10px; font-size:13px; text-decoration:none;">📊 Transactions</a>
                        <a href="/devices/<%= d.token %>/transactions?print=1" target="_blank" class="btn warn" style="padding:6px 10px; font-size:13px; text-decoration:none; margin-left:4px;">🖨️ Imprimer</a>
                        <a href="/devices/<%= d.token %>/pdf" target="_blank" class="btn danger" style="padding:6px 10px; font-size:13px; text-decoration:none; margin-left:4px;">📄 PDF</a>
                        <form method="POST" action="/devices/<%= d.token %>/delete" onsubmit="return confirm('Révoquer ce token ?')" style="display:inline; margin-left:8px;">
                            <button class="btn-link" type="submit">Révoquer</button>
                        </form>
                    </td>
                </tr>
            <% }); %>
            <% if (devices.length === 0) { %>
                <tr><td colspan="5" class="empty">Aucun téléphone inscrit. Créez-en un ci-dessus.</td></tr>
            <% } %>
        </tbody>
    </table>
</section>

<%- include('_layout_foot') %>
