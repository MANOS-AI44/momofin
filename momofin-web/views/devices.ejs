<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>MoMo Fin — Téléphones</title>
    <meta name="theme-color" content="#1565C0">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<header>
    <h1>MoMo Fin — Téléphones</h1>
    <nav>
        <a href="/">Transactions</a>
        <a href="/patron">PATRON</a>
        <a href="/devices" class="active">Téléphones</a>
        <a href="/pdf" target="_blank">PDF</a>
    </nav>
</header>
<main>
    <p>Chaque téléphone APK utilise un token pour s'authentifier. Créez un token par téléphone, puis copiez-le dans MoMo Fin → Paramètres.</p>

    <section class="form">
        <form method="POST" action="/devices">
            <input type="text" name="label" placeholder="Nom du téléphone (ex. Boutique 1)" required />
            <button class="btn primary" type="submit">Créer un token</button>
        </form>
    </section>

    <table>
        <thead>
            <tr><th>Nom</th><th>Token (à copier dans l'APK)</th><th>Créé le</th><th></th></tr>
        </thead>
        <tbody>
            <% devices.forEach(function(d) { %>
                <tr>
                    <td><%= d.label || '—' %></td>
                    <td><code><%= d.token %></code></td>
                    <td><%= new Date(d.created_at).toLocaleString('fr-FR') %></td>
                    <td>
                        <form method="POST" action="/devices/<%= d.token %>/delete" onsubmit="return confirm('Révoquer ce token ?')">
                            <button class="btn-link" type="submit">Révoquer</button>
                        </form>
                    </td>
                </tr>
            <% }); %>
            <% if (devices.length === 0) { %>
                <tr><td colspan="4" class="empty">Aucun téléphone inscrit.</td></tr>
            <% } %>
        </tbody>
    </table>
</main>
</body>
</html>
