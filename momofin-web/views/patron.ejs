<%- include('_layout_head', { pageTitle: 'Mes Comptes — MoMo Fin', activeNav: 'patron', user: user }) %>

<h1>📓 Mes Comptes</h1>
<p class="subtitle">Suivi manuel des entrées et sorties par activité (gestion comptable légère).</p>

<section class="cards">
    <div class="card recu"><span class="label">Entrée</span><strong class="value"><%= fmt(recu) %></strong></div>
    <div class="card sortie"><span class="label">Sortie</span><strong class="value"><%= fmt(sortie) %></strong></div>
    <div class="card solde"><span class="label">Solde</span><strong class="value"><%= fmt(total) %></strong></div>
</section>

<section class="panel">
    <h3>Ajouter une opération</h3>
    <form method="POST" action="/patron" class="filter-row">
        <select name="type" required>
            <option value="RECU">Entrée</option>
            <option value="SORTIE">Sortie</option>
        </select>
        <input type="number" step="0.01" name="amount" placeholder="Montant" required />
        <input type="text" name="note" placeholder="Note (facultatif)" style="flex:1;min-width:200px;" />
        <button class="btn primary" type="submit">Ajouter</button>
    </form>
</section>

<section class="panel">
    <h2>Opérations</h2>
    <table>
        <thead>
            <tr><th>Date</th><th>Type</th><th>Montant</th><th>Note</th><th></th></tr>
        </thead>
        <tbody>
        <% if (entries.length === 0) { %>
            <tr><td colspan="5" class="empty">Aucune entrée.</td></tr>
        <% } %>
        <% entries.forEach(function(e) { %>
            <tr>
                <td><%= new Date(e.ts).toLocaleString('fr-FR') %></td>
                <td><span class="badge <%= e.type === 'RECU' ? 'recu' : 'sortie' %>"><%= e.type === 'RECU' ? 'Entrée' : 'Sortie' %></span></td>
                <td><strong><%= fmt(e.amount) %></strong></td>
                <td><%= e.note || '—' %></td>
                <td>
                    <form method="POST" action="/patron/<%= e.id %>/delete" onsubmit="return confirm('Supprimer cette entrée ?')" style="display:inline">
                        <button class="btn-link" type="submit">Supprimer</button>
                    </form>
                </td>
            </tr>
        <% }); %>
        </tbody>
    </table>
</section>

<%- include('_layout_foot') %>
