<%- include('_layout_head', { pageTitle: 'Mon compte — MoMo Fin', activeNav: 'mon-compte', user: user }) %>

<h1>👤 Mon compte</h1>
<p class="subtitle">Bienvenue <strong><%= user.name || user.email.split('@')[0] %></strong></p>

<% if (bienvenue) { %>
    <section class="panel" style="background:#D1FAE5; border-color:#10B981; color:#065F46;">
        <h2 style="color:#065F46;">🎉 Bienvenue ! Votre compte est créé.</h2>
        <p>Copiez votre code ci-dessous et collez-le dans MoMo Fin sur votre téléphone (bouton « 🔢 J'ai un code d'appareil »).</p>
    </section>
<% } %>

<% devices.forEach(function(d, idx) { %>
    <section class="panel">
        <h2><%= d.label || ('Téléphone ' + (idx+1)) %></h2>

        <% if (d.code) { %>
        <p style="color:#6B7280; font-size:13px; margin:0 0 8px;">🔢 Code court (à dicter à l'utilisateur du téléphone) :</p>
        <div style="display:flex; gap:10px; align-items:stretch;">
            <div id="code-<%= idx %>" style="flex:1; background:#F3E5F5; padding:18px; border-radius:8px; font-size:32px; font-weight:bold; letter-spacing:6px; text-align:center; color:#4A148C; font-family:ui-monospace,monospace;"><%= d.code %></div>
            <button type="button" class="btn purple" onclick="copyText('code-<%= idx %>', this)">Copier</button>
        </div>
        <% } %>

        <p style="margin-top:14px; color:#9CA3AF; font-size:11px;">Token long (alternative pour les anciennes versions de l'app) :</p>
        <div style="display:flex; gap:8px; align-items:stretch;">
            <div id="tok-<%= idx %>" style="flex:1; background:#F9FAFB; padding:8px 12px; border-radius:6px; font-size:10px; font-family:monospace; word-break:break-all; border:1px solid #E5E7EB;"><%= d.token %></div>
            <button type="button" class="btn secondary" onclick="copyText('tok-<%= idx %>', this)">Copier</button>
        </div>

        <p style="margin-top:10px; color:#9CA3AF; font-size:12px;">Créé le <%= new Date(d.created_at).toLocaleString('fr-FR') %></p>

        <form method="POST" action="/mon-compte/revoquer/<%= d.token %>" onsubmit="return confirm('Révoquer ce code ?')" style="display:inline">
            <button type="submit" class="btn-link">Révoquer ce code</button>
        </form>
    </section>
<% }); %>


<section class="panel">
    <h2>🎨 Logo de mon compte</h2>
    <p style="color:#6B7280; font-size:13px; margin:0 0 14px;">Votre logo apparaît automatiquement dans les PDF générés, sur le site et sur la page de téléchargement.</p>

    <% if (user.hasLogo) { %>
        <div style="text-align:center; margin-bottom:14px;">
            <img src="<%= user.logoUrl %>?t=<%= Date.now() %>" alt="Logo actuel" style="max-width:200px; max-height:200px; border:1px solid #E5E7EB; border-radius:8px; padding:8px; background:white;"/>
        </div>
        <form method="POST" action="/mon-compte/logo/supprimer" onsubmit="return confirm('Supprimer le logo actuel ?')" style="text-align:center;">
            <button type="submit" class="btn-link">🗑️ Supprimer le logo actuel</button>
        </form>
        <hr style="margin:14px 0; border:none; border-top:1px solid #E5E7EB;"/>
    <% } %>

    <form method="POST" action="/mon-compte/logo" enctype="multipart/form-data" class="filter-row">
        <input type="file" name="logo" accept="image/png,image/jpeg,image/svg+xml,image/webp" required style="flex:1;min-width:200px;"/>
        <button type="submit" class="btn primary">📤 Téléverser un logo</button>
    </form>

    <p style="color:#9CA3AF; font-size:11px; margin-top:8px;">
        Formats acceptés : PNG, JPG, SVG, WebP &nbsp;·&nbsp; Taille max : 2 MB &nbsp;·&nbsp; Conseil : image carrée (ex. 512×512)
    </p>

    <% if (typeof query !== 'undefined' && query.logo_ok) { %>
        <p style="color:#059669; margin-top:10px;">✅ Logo téléversé avec succès !</p>
    <% } %>
    <% if (typeof query !== 'undefined' && query.logo_error) { %>
        <p style="color:#DC2626; margin-top:10px;">❌ Erreur lors du téléversement (format invalide ou trop volumineux).</p>
    <% } %>
</section>

<section class="panel">
    <h2>+ Nouveau code (nouvelle boutique)</h2>
    <form method="POST" action="/mon-compte/nouveau-token" class="filter-row">
        <input type="text" name="label" placeholder="Nom du téléphone (ex. Boutique 2)" style="flex:1;min-width:240px;" />
        <button type="submit" class="btn success">+ Créer</button>
    </form>
</section>

<script>
function copyText(id, btn) {
    var t = document.getElementById(id).textContent.trim();
    navigator.clipboard.writeText(t).then(function() {
        var old = btn.textContent;
        btn.textContent = '✓ Copié !';
        setTimeout(function() { btn.textContent = old; }, 2000);
    });
}
</script>

<%- include('_layout_foot') %>
