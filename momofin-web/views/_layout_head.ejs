<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= typeof pageTitle === 'string' ? pageTitle : 'MoMo Fin' %></title>
    <meta name="theme-color" content="#1565C0">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="/style.css?v=<%= Date.now() %>">
    <script defer>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
        }
    </script>
</head>
<body>
<div class="app-shell">
    <aside class="sidebar">
        <div class="brand">
            <% if (typeof user !== 'undefined' && user && user.hasLogo) { %>
                <img src="<%= user.logoUrl %>" alt="Logo" style="width:36px; height:36px; object-fit:contain; border-radius:6px; background:white; padding:3px;"/>
            <% } else { %>
                <span class="logo">💰</span>
            <% } %>
            <span class="name">MoMo Fin</span>
        </div>
        <nav>
            <a href="/" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'dashboard') ? 'active' : '' %>">
                <span class="nav-icon">📊</span> Tableau de bord
            </a>
            <a href="/points" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'points') ? 'active' : '' %>">
                <span class="nav-icon">📈</span> MES POINTS
            </a>
            <% if (typeof user !== 'undefined' && user && user.isSubAccount) { %>
                <a href="/patron" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'patron') ? 'active' : '' %>">
                    <span class="nav-icon">📓</span> Mes Comptes
                </a>
            <% } else { %>
                <a href="/comptes" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'comptes') ? 'active' : '' %>">
                    <span class="nav-icon">📓</span> Mes Comptes
                </a>
            <% } %>
            <% if (typeof user === 'undefined' || !user || !user.isSubAccount) { %>
            <a href="/recus-config" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'recus-config') ? 'active' : '' %>">
                <span class="nav-icon">🧾</span> Reçus (config)
            </a>
            <% } %>
            <% if (typeof user === 'undefined' || !user || !user.isSubAccount) { %>
            <a href="/devices" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'devices') ? 'active' : '' %>">
                <span class="nav-icon">📱</span> Mes Appareils
            </a>
            <% } %>
            <% if (typeof user === 'undefined' || !user || !user.isSubAccount) { %>
            <a href="/mon-compte" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'mon-compte') ? 'active' : '' %>">
                <span class="nav-icon">👤</span> Mon compte
            </a>
            <% } %>
            <a href="/telecharger" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'telecharger') ? 'active' : '' %>">
                <span class="nav-icon">📥</span> Télécharger l'app
            </a>
            <a href="/pdf" target="_blank">
                <span class="nav-icon">📄</span> Exporter PDF
            </a>
        </nav>
        <% if (typeof user !== 'undefined' && user) { %>
        <div class="user-info">
            <div class="label">Connecté en tant que</div>
            <div class="name"><%= user.isSubAccount ? user.deviceLabel + ' (sous-compte)' : (user.name || user.email) %></div>
            <a href="/deconnexion" class="logout">↩ Déconnexion</a>
        </div>
        <% } %>
    </aside>
    <main class="app-main">
