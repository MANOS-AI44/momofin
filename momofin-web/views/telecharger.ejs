<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>MoMo Fin — Télécharger</title>
    <meta name="theme-color" content="#1565C0">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="apple-touch-icon" href="/icon-192.svg">
    <link rel="stylesheet" href="/style.css">
    <style>
        .topbar { display:flex; justify-content:space-between; align-items:center; padding:14px 16px; background:#1565C0; color:white; }
        .topbar strong { font-size:18px; }
        .topbar a { color:white; text-decoration:none; padding:8px 14px; border-radius:6px; font-size:14px; margin-left:8px; }
        .topbar a.primary { background:#FFB300; color:#000; font-weight:600; }
        .topbar a.outline { border:1px solid rgba(255,255,255,0.6); }
        .hero { text-align:center; padding:36px 16px 24px; }
        .hero h1 { font-size:32px; margin:0; color:#1565C0; }
        .hero p { color:#555; margin:8px 0 0; }
        .signup-banner {
            max-width:680px; margin:20px auto 0; padding:18px 22px;
            background:linear-gradient(135deg,#FFF8E1,#FFE082);
            border-radius:12px; border-left:4px solid #FFB300;
            color:#5d4037; font-size:15px;
        }
        .signup-banner h3 { margin:0 0 6px; color:#000; }
        .signup-banner a.cta {
            display:inline-block; margin-top:10px; padding:10px 22px;
            background:#1565C0; color:white; text-decoration:none; border-radius:6px;
            font-weight:600;
        }
        .dl-grid { display:grid; gap:18px; grid-template-columns:1fr; max-width:680px; margin:24px auto; padding:0 16px; }
        @media (min-width: 720px) { .dl-grid { grid-template-columns: 1fr 1fr; } }
        .dl-card { background:white; border-radius:12px; padding:22px; box-shadow:0 2px 8px rgba(0,0,0,0.08); text-align:center; }
        .dl-card .icon { font-size:48px; line-height:1; margin-bottom:8px; }
        .dl-card h2 { margin:0 0 6px; font-size:20px; color:#1a1a1a; }
        .dl-card p { color:#666; font-size:14px; margin:0 0 16px; min-height:42px; }
        .dl-btn { display:inline-block; padding:14px 22px; background:#1565C0; color:white; text-decoration:none; border-radius:8px; font-weight:600; font-size:15px; width:100%; box-sizing:border-box; }
        .dl-btn:hover { background:#0D47A1; }
        .dl-btn.alt { background:#2E7D32; }
        .dl-btn.web { background:#FFB300; color:#000; }
        .dl-btn.disabled { background:#bbb; cursor:not-allowed; pointer-events:none; }
        .install-info { max-width:680px; margin:0 auto 32px; padding:18px; background:#fff8e1; border-left:4px solid #FFB300; border-radius:6px; color:#5d4037; font-size:14px; }
        .install-info h3 { margin:0 0 8px; color:#000; font-size:15px; }
        .install-info ol { margin:6px 0 0 18px; padding:0; }
        .install-info li { margin-bottom:4px; }
        .footer-mini { text-align:center; color:#888; font-size:13px; padding:24px; }
    </style>
</head>
<body>

<div class="topbar">
    <strong>📱 MoMo Fin</strong>
    <div>
        <% if (typeof user !== 'undefined' && user) { %>
            <a href="/mon-compte" class="primary">Mon compte</a>
            <a href="/deconnexion" class="outline">Déconnexion</a>
        <% } else { %>
            <a href="/connexion" class="outline">Connexion</a>
            <a href="/inscription" class="primary">Créer un compte</a>
        <% } %>
    </div>
</div>

<div class="hero">
    <h1>MoMo Fin</h1>
    <p>Suivi des transactions Mobile Money — téléchargement direct, sans Play Store.</p>
</div>

<% if (typeof user === 'undefined' || !user) { %>
    <div class="signup-banner" style="max-width:680px;">
        <h3>💡 Avant d'installer l'application</h3>
        <p style="margin:6px 0 0;">Créez un compte gratuit pour obtenir votre <strong>code personnel</strong>. Vous le collerez dans l'application Android pour qu'elle envoie vos transactions vers votre tableau de bord privé.</p>
        <a href="/inscription" class="cta">Créer mon compte gratuit →</a>
    </div>
<% } %>

<div class="dl-grid">
    <div class="dl-card">
        <div class="icon">📨</div>
        <h2>MoMo SMS</h2>
        <p>Lit automatiquement les SMS Mobile Money (MTN, Orange, Airtel) sur votre téléphone.</p>
        <% if (smsApk) { %>
            <a class="dl-btn" href="<%= smsApk %>">⬇ Télécharger MoMo SMS</a>
        <% } else { %>
            <a class="dl-btn disabled" href="#">APK indisponible</a>
        <% } %>
    </div>

    <div class="dl-card">
        <div class="icon">💰</div>
        <h2>MoMo Fin</h2>
        <p>Tableau de bord, génération PDF par jour et section PATRON (Reçu / Sortie / Total).</p>
        <% if (finApk) { %>
            <a class="dl-btn alt" href="<%= finApk %>">⬇ Télécharger MoMo Fin</a>
        <% } else { %>
            <a class="dl-btn disabled" href="#">APK indisponible</a>
        <% } %>
    </div>

    <div class="dl-card" style="grid-column: 1 / -1;">
        <div class="icon">🌐</div>
        <h2>Version Web (sans installation)</h2>
        <p>Préférez utiliser MoMo Fin directement depuis votre navigateur ? La version web est installable comme une application sur Android.</p>
        <a class="dl-btn web" id="btnInstallPwa" href="<%= webAppUrl %>">📲 Ouvrir / Installer la version web</a>
    </div>
</div>

<div class="install-info">
    <h3>Comment installer et activer</h3>
    <ol>
        <li><strong>Créez votre compte</strong> sur ce site → vous recevez un <em>code personnel</em></li>
        <li>Téléchargez l'APK <strong>MoMo Fin</strong> avec le bouton vert ci-dessus</li>
        <li>Ouvrez le fichier <code>.apk</code> téléchargé → autoriser <em>« Installer des applications inconnues »</em></li>
        <li>Lancez MoMo Fin → bouton <strong>Paramètres</strong></li>
        <li>Collez votre code personnel dans <strong>Token du téléphone</strong></li>
        <li>Appuyez sur <strong>Tester</strong>, puis <strong>Enregistrer</strong></li>
        <li>De retour à l'écran principal, appuyez sur <strong>Synchroniser</strong> — vos SMS apparaissent dans votre tableau de bord</li>
    </ol>
</div>

<div class="footer-mini">
    Code source ouvert · <a href="/" style="color:#1565C0;">Tableau de bord (admin)</a>
</div>

<script>
    let deferredPrompt = null;
    window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
    });
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
</script>

</body>
</html>
