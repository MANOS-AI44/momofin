<%
function subtypeLabel(st, type) {
    if (st === 'DEPOT') return 'Dépôt';
    if (st === 'RETRAIT') return 'Retrait';
    if (st === 'TRANSFERT_ENVOYE') return 'Transfert envoyé';
    if (st === 'TRANSFERT_RECU') return 'Transfert reçu';
    // Fallback sur type si subtype absent
    if (type === 'RECU') return 'Retrait';
    if (type === 'SORTIE') return 'Dépôt';
    return '—';
}
function subtypeBadge(st, type) {
    if (st === 'DEPOT' || type === 'SORTIE') return 'sortie';
    if (st === 'RETRAIT' || type === 'RECU') return 'recu';
    if (st === 'TRANSFERT_ENVOYE') return 'sortie';
    if (st === 'TRANSFERT_RECU') return 'recu';
    return '';
}
%>
<%
function phoneOp(phone) {
    if (!phone) return '';
    const p2 = String(phone).substring(0, 2);
    if (p2 === '07' || p2 === '08' || p2 === '09') return 'Orange';
    if (p2 === '05' || p2 === '04' || p2 === '06') return 'MTN';
    if (p2 === '01' || p2 === '02' || p2 === '03') return 'MOOV';
    return '';
}
function phoneOpColor(op) {
    if (op === 'Orange') return '#F97316';
    if (op === 'MTN') return '#EAB308';
    if (op === 'MOOV') return '#3B82F6';
    return '#9CA3AF';
}
%>
<%- include('_layout_head', { pageTitle: 'Tableau de bord — MoMo Fin', activeNav: 'dashboard', user: user }) %>

<h1>📊 Tableau de bord</h1>
<p class="subtitle">Compte : <strong><%= accountName %></strong></p>

<section class="panel print-hide">
    <h3>📅 Période</h3>
    <div class="filter-bar">
        <% var p = (typeof from === 'undefined' || !from) ? 'all' : ''; %>
        <a href="/" class="preset-btn <%= p==='all' ? 'active' : '' %>">Tout</a>
        <a href="/?preset=today" class="preset-btn">Aujourd'hui</a>
        <a href="/?preset=week" class="preset-btn">7 jours</a>
        <a href="/?preset=month" class="preset-btn">Ce mois</a>
        <a href="/?preset=year" class="preset-btn">Cette année</a>
    </div>
    <form method="GET" action="/" class="filter-row">
        <label>Du <input type="date" name="from" value="<%= from ? from.toISOString().substring(0,10) : '' %>"></label>
        <label>Au <input type="date" name="to" value="<%= to ? to.toISOString().substring(0,10) : '' %>"></label>
        <button type="submit" class="btn primary">Filtrer</button>
        <button type="button" onclick="window.print()" class="btn warn">🖨️ Imprimer</button>
        <a href="/pdf<%= from ? ('?from=' + from.toISOString().substring(0,10) + '&to=' + (to ? to.toISOString().substring(0,10) : '')) : '' %>" target="_blank" class="btn danger">📄 PDF</a>
        <% if (typeof user !== "undefined" && user && !user.isSubAccount) { %><a href="/nettoyer-transactions" class="btn warn" style="margin-left:auto;" title="Re-parser toutes les transactions, deduplique et corrige les types/montants">🔄 Re-traiter</a><% } %>
    </form>
</section>

<% if (typeof deviceTotals !== 'undefined' && deviceTotals && deviceTotals.length > 0) { %>
    <section class="panel">
        <h2>👥 Bilan par assistant (<%= deviceTotals.length %>)</h2>
        <p class="subtitle">Activite de chaque assistant/boutique sur la periode choisie. Cliquez sur un nom pour le detail.</p>
        <%
        function relTime(iso) {
            if (!iso) return '—';
            var d = new Date(iso); var diff = Date.now() - d.getTime();
            var mn = Math.floor(diff / 60000);
            if (mn < 1) return "a l'instant";
            if (mn < 60) return 'il y a ' + mn + ' min';
            var h = Math.floor(mn / 60); if (h < 24) return 'il y a ' + h + ' h';
            var j = Math.floor(h / 24); if (j < 7) return 'il y a ' + j + ' jour' + (j>1?'s':'');
            return d.toLocaleDateString('fr-FR');
        }
        %>
        <table>
            <thead>
                <tr>
                    <th>Boutique</th>
                    <th>Code</th>
                    <th style="text-align:center;">SMS captures</th>
                    <th style="text-align:center;">Jours actifs</th>
                    <th style="text-align:center;">Saisies manuelles</th>
                    <th style="text-align:right;">Total Retrait</th>
                    <th style="text-align:right;">Total Dépôt</th>
                    <th style="text-align:right;">Solde</th>
                    <th>Derniere activite</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            <% deviceTotals.forEach(function(d) { %>
                <tr>
                    <td><strong><%= d.label || '—' %></strong></td>
                    <td><strong style="color:#1565C0; letter-spacing:2px;"><%= d.code || '—' %></strong></td>
                    <td style="text-align:center;"><strong><%= d.nb_tx %></strong></td>
                    <td style="text-align:center; color:#6B7280;"><%= d.nb_jours %></td>
                    <td style="text-align:center; color:#7C3AED;"><strong><%= d.nb_patron %></strong></td>
                    <td style="text-align:right; color:#059669;"><strong><%= fmt(d.recu) %></strong></td>
                    <td style="text-align:right; color:#DC2626;"><strong><%= fmt(d.sortie) %></strong></td>
                    <td style="text-align:right;"><strong style="color:<%= (d.recu - d.sortie) >= 0 ? '#059669' : '#DC2626' %>;"><%= fmt(d.recu - d.sortie) %></strong></td>
                    <td style="color:#6B7280; font-size:12px; white-space:nowrap;"><%= relTime(d.lastActivity) %></td>
                    <td style="text-align:right; white-space:nowrap;">
                        <%
                            var devQs = from ? ('?from=' + from.toISOString().substring(0,10) + '&to=' + (to ? to.toISOString().substring(0,10) : '')) : '';
                            var printQs = devQs ? devQs + '&print=1' : '?print=1';
                        %>
                        <a href="/devices/<%= d.token %>/transactions<%= devQs %>"
                           class="btn primary" style="padding:6px 10px; font-size:13px; text-decoration:none;">📊 Voir</a>
                        <a href="/devices/<%= d.token %>/transactions<%= printQs %>" target="_blank"
                           class="btn warn" style="padding:6px 10px; font-size:13px; text-decoration:none; margin-left:4px;">🖨️ Imprimer</a>
                        <a href="/devices/<%= d.token %>/pdf<%= devQs %>" target="_blank"
                           class="btn danger" style="padding:6px 10px; font-size:13px; text-decoration:none; margin-left:4px;">📄 PDF</a>
                    </td>
                </tr>
            <% }); %>
            </tbody>
        </table>
    </section>
<% } %>

<% if (days.length === 0) { %>
    <p class="empty">Aucune transaction reçue pour l'instant. Synchronisez depuis l'APK MoMo Fin.</p>
<% } %>

<% days.forEach(function(d) { %>
    <section class="day">
        <h2><%= new Date(d.day).toLocaleDateString('fr-FR', { weekday:'long', day:'2-digit', month:'long', year:'numeric' }) %></h2>
        <p class="day-totals">
            <strong style="color:#059669;">Total Retrait : <%= fmt(d.recu) %></strong>
             &nbsp;·&nbsp;
            <strong style="color:#DC2626;">Total Dépôt : <%= fmt(d.sortie) %></strong>
        </p>
        <table>
            <thead>
                <tr><th>Date/Heure</th><th>Type</th><th>Montant</th><th>Numéro</th><th>Référence</th><th>Opérateur</th></tr>
            </thead>
            <tbody>
            <% d.list.forEach(function(t) { %>
                <tr>
                    <td><%= new Date(t.ts).toLocaleString('fr-FR') %></td>
                    <td><span class="badge <%= subtypeBadge(t.subtype, t.type) %>"><%= subtypeLabel(t.subtype, t.type) %></span></td>
                    <td><strong><%= fmt(t.amount) %></strong> <%= t.currency || '' %></td>
                    <td><%= t.phone_number || '—' %></td>
                    <td><code><%= t.reference || '—' %></code></td>
                    <td><% var opEff = phoneOp(t.phone_number); %><%= (opEff || t.operator || 'Autre') %></td>
                </tr>
            <% }); %>
            </tbody>
        </table>
    </section>
<% }); %>

<%- include('_layout_foot') %>
