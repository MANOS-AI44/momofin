<% /* Dashboard transactions, simple sans système d'include layout */ %>
<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>MoMo Fin — Transactions</title>
    <meta name="theme-color" content="#1565C0">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="apple-touch-icon" href="/icon-192.svg">
    <link rel="stylesheet" href="/style.css">
    <script defer>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
        }
    </script>
</head>
<body>
<header>
    <h1>MoMo Fin</h1>
    <nav>
        <a href="/" class="active">Transactions</a>
        <a href="/patron">PATRON</a>
        <a href="/devices">Téléphones</a>
        <a href="/pdf" target="_blank">PDF</a>
    </nav>
</header>
<main>
    <section class="cards">
        <div class="card recu">
            <span>Total Reçu</span>
            <strong><%= fmt(totals.recu) %></strong>
        </div>
        <div class="card sortie">
            <span>Total Sortie</span>
            <strong><%= fmt(totals.sortie) %></strong>
        </div>
        <div class="card solde">
            <span>Solde global</span>
            <strong><%= fmt(totals.recu - totals.sortie) %></strong>
        </div>
    </section>

    <% if (days.length === 0) { %>
        <p class="empty">Aucune transaction reçue pour l'instant. Synchronisez depuis l'APK MoMo Fin.</p>
    <% } %>

    <% days.forEach(function(d) { %>
        <section class="day">
            <h2><%= new Date(d.day).toLocaleDateString('fr-FR', { weekday:'long', day:'2-digit', month:'long', year:'numeric' }) %></h2>
            <p class="day-totals">
                Reçu <strong><%= fmt(d.recu) %></strong> · Sortie <strong><%= fmt(d.sortie) %></strong> · Solde <strong><%= fmt(d.solde) %></strong>
            </p>
            <table>
                <thead>
                    <tr><th>Heure</th><th>Type</th><th>Montant</th><th>Référence</th><th>Opérateur</th></tr>
                </thead>
                <tbody>
                <% d.list.forEach(function(t) { %>
                    <tr class="<%= t.type === 'RECU' ? 'recu' : (t.type === 'SORTIE' ? 'sortie' : '') %>">
                        <td><%= new Date(t.ts).toLocaleTimeString('fr-FR') %></td>
                        <td><%= t.type === 'RECU' ? 'Reçu' : (t.type === 'SORTIE' ? 'Sortie' : '—') %></td>
                        <td><strong><%= fmt(t.amount) %></strong> <%= t.currency || '' %></td>
                        <td><%= t.reference || '—' %></td>
                        <td><%= t.operator || '' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </section>
    <% }); %>
</main>
</body>
</html>
