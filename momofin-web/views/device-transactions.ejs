<%
function subtypeLabel(st, type) {
    if (st === 'DEPOT') return 'Dépôt';
    if (st === 'RETRAIT') return 'Retrait';
    if (st === 'TRANSFERT_ENVOYE') return 'Transfert envoyé';
    if (st === 'TRANSFERT_RECU') return 'Transfert reçu';
    // Fallback sur type si subtype absent
    if (type === 'RECU') return 'Retrait';
    if (type === 'SORTIE') return 'Dépôt';
    return '—';
}
function subtypeBadge(st, type) {
    if (st === 'DEPOT' || type === 'SORTIE') return 'sortie';
    if (st === 'RETRAIT' || type === 'RECU') return 'recu';
    if (st === 'TRANSFERT_ENVOYE') return 'sortie';
    if (st === 'TRANSFERT_RECU') return 'recu';
    return '';
}
%>
<script id="autoprint-script">
    if (new URLSearchParams(window.location.search).get('print') === '1') {
        window.addEventListener('load', function() { setTimeout(function() { window.print(); }, 400); });
    }
</script>
<%
function phoneOp(phone) {
    if (!phone) return '';
    const p2 = String(phone).substring(0, 2);
    if (p2 === '07' || p2 === '08' || p2 === '09') return 'Orange';
    if (p2 === '05' || p2 === '04' || p2 === '06') return 'MTN';
    if (p2 === '01' || p2 === '02' || p2 === '03') return 'MOOV';
    return '';
}
function phoneOpColor(op) {
    if (op === 'Orange') return '#F97316';
    if (op === 'MTN') return '#EAB308';
    if (op === 'MOOV') return '#3B82F6';
    return '#9CA3AF';
}
%>
<%- include('_layout_head', { pageTitle: 'Transactions de l\'appareil — MoMo Fin', activeNav: 'devices', user: user }) %>

<h1>📊 Transactions — <%= device.label || 'Appareil' %></h1>
<p class="subtitle">
    Code court : <strong style="color:#1565C0; letter-spacing:2px;"><%= device.code || '—' %></strong>
    &nbsp;·&nbsp;
    <a href="/devices" style="color:#6B7280;">← Retour aux appareils</a>
</p>

<section class="panel print-hide">
    <h3>📅 Période</h3>
    <div class="filter-bar">
        <% var pAll = (typeof from === 'undefined' || !from) ? 'active' : ''; %>
        <a href="/devices/<%= device.token %>/transactions" class="preset-btn <%= pAll %>">Tout</a>
        <a href="/devices/<%= device.token %>/transactions?preset=today" class="preset-btn">Aujourd'hui</a>
        <a href="/devices/<%= device.token %>/transactions?preset=week" class="preset-btn">7 jours</a>
        <a href="/devices/<%= device.token %>/transactions?preset=month" class="preset-btn">Ce mois</a>
        <a href="/devices/<%= device.token %>/transactions?preset=year" class="preset-btn">Cette année</a>
    </div>
    <form method="GET" action="/devices/<%= device.token %>/transactions" class="filter-row">
        <label>Du <input type="date" name="from" value="<%= from ? from.toISOString().substring(0,10) : '' %>"></label>
        <label>Au <input type="date" name="to" value="<%= to ? to.toISOString().substring(0,10) : '' %>"></label>
        <% if (typeFilter) { %><input type="hidden" name="type" value="<%= typeFilter %>"><% } %>
        <button type="submit" class="btn primary">Filtrer</button>
    </form>
</section>

<section class="panel print-hide">
    <h3>📋 Type de transaction</h3>
    <%
        function qs(extra) {
            var parts = [];
            if (from) parts.push('from=' + from.toISOString().substring(0,10));
            if (to)   parts.push('to=' + to.toISOString().substring(0,10));
            if (extra) parts.push(extra);
            return parts.length ? '?' + parts.join('&') : '';
        }
    %>
    <div class="filter-bar">
        <a href="/devices/<%= device.token %>/transactions<%= qs() %>" class="preset-btn <%= !typeFilter ? 'active' : '' %>">Tout</a>
        <a href="/devices/<%= device.token %>/transactions<%= qs('type=DEPOT') %>" class="preset-btn <%= typeFilter === 'DEPOT' ? 'active' : '' %>">📥 Dépôt</a>
        <a href="/devices/<%= device.token %>/transactions<%= qs('type=RETRAIT') %>" class="preset-btn <%= typeFilter === 'RETRAIT' ? 'active' : '' %>">💸 Retrait</a>
        <a href="/devices/<%= device.token %>/transactions<%= qs('type=TRANSFERT_ENVOYE') %>" class="preset-btn <%= typeFilter === 'TRANSFERT_ENVOYE' ? 'active' : '' %>">📤 Transfert envoyé</a>
        <a href="/devices/<%= device.token %>/transactions<%= qs('type=TRANSFERT_RECU') %>" class="preset-btn <%= typeFilter === 'TRANSFERT_RECU' ? 'active' : '' %>">📥 Transfert reçu</a>
    </div>
    <div class="filter-row" style="margin-top:12px;">
        <button type="button" onclick="window.print()" class="btn warn">🖨️ Imprimer la liste</button>
        <a href="/devices/<%= device.token %>/pdf<%= qs(typeFilter ? 'type=' + typeFilter : '') %>" target="_blank" class="btn danger">📄 Télécharger PDF</a>
    </div>
</section>

<% if (days.length === 0) { %>
    <p class="empty">Aucune transaction pour cet appareil sur la période choisie.</p>
<% } else { %>
    <section class="panel" style="background:#F9FAFB;">
        <h3>🧮 Totaux de la période</h3>
        <p style="font-size:16px;">
            <strong style="color:#059669;">Total Retrait : <%= fmt(totals.recu) %></strong>
             &nbsp;·&nbsp;
            <strong style="color:#DC2626;">Total Dépôt : <%= fmt(totals.sortie) %></strong>
        </p>
    </section>
<% } %>

<% days.forEach(function(d) { %>
    <section class="day">
        <h2><%= new Date(d.day).toLocaleDateString('fr-FR', { weekday:'long', day:'2-digit', month:'long', year:'numeric' }) %></h2>
        <p class="day-totals">
            <strong style="color:#059669;">Total Retrait : <%= fmt(d.recu) %></strong>
             &nbsp;·&nbsp;
            <strong style="color:#DC2626;">Total Dépôt : <%= fmt(d.sortie) %></strong>
        </p>
        <table>
            <thead>
                <tr><th>Date/Heure</th><th>Type</th><th>Montant</th><th>Numéro</th><th>Référence</th><th>Opérateur</th></tr>
            </thead>
            <tbody>
            <% d.list.forEach(function(t, idx) { var rid = 'r_' + d.day.replace(/[^a-z0-9]/gi,'') + '_' + idx; %>
                <tr class="tx-row" onclick="document.getElementById('<%= rid %>').classList.toggle('show')" style="cursor:pointer;">
                    <td><%= new Date(t.ts).toLocaleString('fr-FR') %></td>
                    <td><span class="badge <%= subtypeBadge(t.subtype, t.type) %>"><%= subtypeLabel(t.subtype, t.type) %></span></td>
                    <td><strong><%= fmt(t.amount) %></strong> <%= t.currency || '' %></td>
                    <td><%= t.phone_number || '—' %></td>
                    <td><code><%= t.reference || '—' %></code></td>
                    <td><% var opEff = phoneOp(t.phone_number); %><%= (opEff || t.operator || 'Autre') %></td>
                </tr>
                <tr id="<%= rid %>" class="tx-detail" style="display:none;">
                    <td colspan="6" style="background:#F9FAFB; padding:16px; border-top:none;">
                        <%
                            var frais = (t.raw_body || '').match(/(?:frais)[^\d]{0,20}([\d\s.,]+)\s*(FCFA|CFA|F)/i);
                            var solde = (t.raw_body || '').match(/(?:nouveau\s+)?solde[^\d]{0,30}([\d\s.,]+)\s*(FCFA|CFA|F)/i);
                        %>
                        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:12px; margin-bottom:14px;">
                            <div><div style="font-size:11px; color:#9CA3AF; text-transform:uppercase;">Expéditeur SMS</div><div><strong><%= t.raw_sender || '—' %></strong></div></div>
                            <div><div style="font-size:11px; color:#9CA3AF; text-transform:uppercase;">Frais</div><div><%= frais ? frais[1].trim() + ' ' + frais[2] : '—' %></div></div>
                            <div><div style="font-size:11px; color:#9CA3AF; text-transform:uppercase;">Nouveau solde</div><div><%= solde ? solde[1].trim() + ' ' + solde[2] : '—' %></div></div>
                            <div><div style="font-size:11px; color:#9CA3AF; text-transform:uppercase;">Date/heure complete</div><div><%= new Date(t.ts).toLocaleString('fr-FR', {weekday:'long', day:'2-digit', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit', second:'2-digit'}) %></div></div>
                        </div>
                        <div style="font-size:11px; color:#9CA3AF; text-transform:uppercase; margin-bottom:4px;">📨 SMS Original</div>
                        <pre style="background:white; padding:12px; border-radius:6px; border:1px solid #E5E7EB; white-space:pre-wrap; word-break:break-word; font-size:12px; margin:0; font-family:monospace;"><%= t.raw_body || '(non disponible)' %></pre>
                    </td>
                </tr>
            <% }); %>
            </tbody>
        </table>
    </section>
<% }); %>

<%- include('_layout_foot') %>
