<%- include('_layout_head', { pageTitle: 'Config des reçus — MoMo Fin', activeNav: 'recus-config', user: user }) %>

<h1>🧾 Configuration des reçus</h1>
<p class="subtitle">Définissez les règles affichées en bas de chaque reçu et téléversez votre cachet.</p>

<% if (typeof user !== 'undefined' && user) { %>
<section class="panel">
    <h2>📜 Règles / conditions</h2>
    <p class="subtitle">Ce texte apparaîtra en bas de chaque reçu généré par vos boutiques.</p>
    <form method="POST" action="/recus-config/regles">
        <textarea name="rules" rows="6" style="width:100%; padding:12px; border:1px solid #D1D5DB; border-radius:8px; font-family:inherit; font-size:14px;" placeholder="Exemple : Aucune réclamation acceptée après 48h. Tout achat effectué est sous votre entière responsabilité. La maison décline toute responsabilité..."><%= rules %></textarea>
        <button type="submit" class="btn primary" style="margin-top:12px;">💾 Enregistrer les règles</button>
    </form>
</section>

<section class="panel">
    <h2>🖋️ Cachet</h2>
    <p class="subtitle">Prenez votre cachet en photo et téléversez-le. Il apparaîtra sur chaque reçu.</p>
    <% if (hasCachet) { %>
        <div style="margin:12px 0;">
            <img src="/cachet/<%= user.id %>?v=<%= Date.now() %>" alt="Cachet" style="max-width:180px; max-height:180px; border:1px solid #E5E7EB; border-radius:8px; padding:8px; background:white;">
        </div>
        <form method="POST" action="/recus-config/cachet/supprimer" style="display:inline;">
            <button type="submit" class="btn-link" onclick="return confirm('Supprimer le cachet ?')">Supprimer le cachet</button>
        </form>
    <% } else { %>
        <p class="empty">Aucun cachet téléversé pour l'instant.</p>
    <% } %>
    <form method="POST" action="/recus-config/cachet" enctype="multipart/form-data" style="margin-top:12px;">
        <input type="file" name="cachet" accept="image/*" required>
        <button type="submit" class="btn success" style="margin-top:8px;">⬆️ Téléverser le cachet</button>
    </form>
    <p style="font-size:12px; color:#6B7280; margin-top:8px;">Conseil : photographiez le cachet sur fond blanc, image nette. PNG avec fond transparent idéal.</p>
</section>

<% if (typeof query !== 'undefined') { %><% } %>
<% } else { %>
<p class="empty">Connectez-vous en tant qu'administrateur.</p>
<% } %>

<%- include('_layout_foot') %>
