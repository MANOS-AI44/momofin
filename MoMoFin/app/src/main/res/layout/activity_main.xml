<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header app (compact : titre + date + boutons sur 1 seule ligne) -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Title.H1"
                    android:textSize="16sp"
                    android:text="@string/app_name"/>
                <Button
                    android:id="@+id/btnPickDate"
                    style="@style/Btn.Outline"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="📅 Toutes"
                    android:textSize="12sp"
                    android:paddingHorizontal="8dp"
                    android:singleLine="true"
                    android:ellipsize="end"/>
                <Button
                    android:id="@+id/btnClearDate"
                    style="@style/Btn.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:text="✕"
                    android:textSize="12sp"
                    android:minWidth="38dp"
                    android:paddingHorizontal="6dp"
                    android:visibility="gone"/>
                <Button
                    android:id="@+id/btnDevices"
                    style="@style/Btn.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:text="📱"
                    android:textSize="14sp"
                    android:paddingHorizontal="10dp"
                    android:minWidth="40dp"/>
                <Button
                    android:id="@+id/btnSettings"
                    style="@style/Btn.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:text="⚙️"
                    android:textSize="14sp"
                    android:paddingHorizontal="10dp"
                    android:minWidth="40dp"/>
            </LinearLayout>

            <!-- Texte selectionne (cache : on garde la TextView pour compat, mais invisible) -->
            <TextView
                android:id="@+id/txtSelectedDate"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

            <!-- Bannière notifications -->
            <LinearLayout
                android:id="@+id/bannerNotifAccess"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/banner_warning"
                android:visibility="gone">
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#E65100"
                        android:text="@string/notif_access_title"/>
                    <Button android:id="@+id/btnDismissNotif"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✕" android:textSize="14sp" android:minWidth="40dp"
                        style="?android:attr/borderlessButtonStyle" android:textColor="#E65100"/>
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textSize="12sp" android:textColor="#5d4037"
                    android:text="@string/notif_access_msg"/>
                <Button
                    android:id="@+id/btnNotifAccess"
                    style="@style/Btn.Warning"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/notif_access_btn"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Bannière SMS -->
            <LinearLayout
                android:id="@+id/bannerPerms"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:layout_marginTop="10dp"
                android:background="#FFFDE7"
                android:visibility="gone">
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#F57F17"
                        android:text="@string/perm_banner_title"/>
                    <Button android:id="@+id/btnDismissPerms"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✕" android:textSize="14sp" android:minWidth="40dp"
                        style="?android:attr/borderlessButtonStyle" android:textColor="#F57F17"/>
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textSize="12sp" android:textColor="#5d4037"
                    android:text="@string/perm_banner_message"/>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp">
                    <Button android:id="@+id/btnRequestPerms"
                        style="@style/Btn.Outline"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
                        android:text="@string/perm_btn_ask" android:textSize="12sp"/>
                    <Button android:id="@+id/btnOpenAppSettings"
                        style="@style/Btn.Warning"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:text="@string/perm_btn_settings" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Indicateur Android version -->
            <TextView
                android:id="@+id/txtAndroidVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                style="@style/Subtitle"/>

            <!-- Recherche par numero (discret) -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:text="🔍"/>
                <EditText
                    android:id="@+id/edtSearch"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:hint="Rechercher un numero, une reference..."
                    android:textSize="12sp"
                    android:padding="6dp"
                    android:singleLine="true"
                    android:inputType="text"
                    android:imeOptions="actionSearch"/>
                <Button
                    android:id="@+id/btnClearSearch"
                    style="@style/Btn.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:text="✕"
                    android:textSize="12sp"
                    android:minWidth="40dp"
                    android:paddingHorizontal="8dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Filtres categorie -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:scrollbars="none">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView android:id="@+id/chipAll"      android:layout_width="wrap_content" android:layout_height="32dp"
                              android:text="Tout"             android:textSize="12sp" android:gravity="center" android:paddingHorizontal="14dp"
                              android:layout_marginEnd="6dp" android:background="@drawable/chip_active" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/chipDepot"    android:layout_width="wrap_content" android:layout_height="32dp"
                              android:text="📥 Dépôt"         android:textSize="12sp" android:gravity="center" android:paddingHorizontal="14dp"
                              android:layout_marginEnd="6dp" android:background="@drawable/chip_inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/chipRetrait"  android:layout_width="wrap_content" android:layout_height="32dp"
                              android:text="💸 Retrait"       android:textSize="12sp" android:gravity="center" android:paddingHorizontal="14dp"
                              android:layout_marginEnd="6dp" android:background="@drawable/chip_inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/chipTEnvoye"  android:layout_width="wrap_content" android:layout_height="32dp"
                              android:text="📤 T. envoyé"     android:textSize="12sp" android:gravity="center" android:paddingHorizontal="14dp"
                              android:layout_marginEnd="6dp" android:background="@drawable/chip_inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/chipTRecu"    android:layout_width="wrap_content" android:layout_height="32dp"
                              android:text="📩 T. reçu"       android:textSize="12sp" android:gravity="center" android:paddingHorizontal="14dp"
                              android:background="@drawable/chip_inactive" android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Résumé -->
            <TextView
                android:id="@+id/txtSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="10dp"
                android:background="#F9FAFB"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:text="@string/loading"/>

            <!-- Actions principales -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <Button
                    android:id="@+id/btnRefresh"
                    style="@style/Btn.Outline"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="46dp"
                    android:text="🔄 Actualiser"
                    android:textSize="13sp"/>
                <Button
                    android:id="@+id/btnPdf"
                    style="@style/Btn.Warning"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="46dp"
                    android:layout_marginStart="6dp"
                    android:text="📄 PDF"
                    android:textSize="13sp"/>
                <Button
                    android:id="@+id/btnSync"
                    style="@style/Btn.Success"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="46dp"
                    android:layout_marginStart="6dp"
                    android:text="☁️ Sync"
                    android:textSize="13sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="280dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Boutons sticky en bas -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="10dp"
        android:elevation="12dp">
        <Button
            android:id="@+id/btnPatron"
            style="@style/Btn.Warning"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:text="📓 Mes Comptes"
            android:textSize="13sp"/>
        <Button
            android:id="@+id/btnPoints"
            style="@style/Btn.Purple"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="📊 Mes Points"
            android:textSize="13sp"/>
        <Button
            android:id="@+id/btnOpenWeb"
            style="@style/Btn.Primary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="🌐 Site web"
            android:textSize="13sp"/>
    </LinearLayout>
</LinearLayout>
