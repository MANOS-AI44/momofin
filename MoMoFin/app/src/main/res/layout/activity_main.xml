<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header app -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    style="@style/Title.H1"
                    android:text="@string/app_name"/>
                <Button
                    android:id="@+id/btnDevices"
                    style="@style/Btn.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="📱"
                    android:textSize="16sp"
                    android:paddingHorizontal="12dp"
                    android:minWidth="48dp"/>
                <Button
                    android:id="@+id/btnSettings"
                    style="@style/Btn.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:text="⚙️"
                    android:textSize="16sp"
                    android:paddingHorizontal="12dp"
                    android:minWidth="48dp"/>
            </LinearLayout>

            <!-- Bannière notifications -->
            <LinearLayout
                android:id="@+id/bannerNotifAccess"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/banner_warning"
                android:visibility="gone">
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#E65100"
                        android:text="@string/notif_access_title"/>
                    <Button android:id="@+id/btnDismissNotif"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✕" android:textSize="14sp" android:minWidth="40dp"
                        style="?android:attr/borderlessButtonStyle" android:textColor="#E65100"/>
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textSize="12sp" android:textColor="#5d4037"
                    android:text="@string/notif_access_msg"/>
                <Button
                    android:id="@+id/btnNotifAccess"
                    style="@style/Btn.Warning"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/notif_access_btn"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Bannière SMS -->
            <LinearLayout
                android:id="@+id/bannerPerms"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:layout_marginTop="10dp"
                android:background="#FFFDE7"
                android:visibility="gone">
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#F57F17"
                        android:text="@string/perm_banner_title"/>
                    <Button android:id="@+id/btnDismissPerms"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✕" android:textSize="14sp" android:minWidth="40dp"
                        style="?android:attr/borderlessButtonStyle" android:textColor="#F57F17"/>
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textSize="12sp" android:textColor="#5d4037"
                    android:text="@string/perm_banner_message"/>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp">
                    <Button android:id="@+id/btnRequestPerms"
                        style="@style/Btn.Outline"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
                        android:text="@string/perm_btn_ask" android:textSize="12sp"/>
                    <Button android:id="@+id/btnOpenAppSettings"
                        style="@style/Btn.Warning"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:text="@string/perm_btn_settings" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Indicateur Android version -->
            <TextView
                android:id="@+id/txtAndroidVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                style="@style/Subtitle"/>

            <!-- Filtre date -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:background="@drawable/banner_info"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:text="📅"/>
                <TextView
                    android:id="@+id/txtSelectedDate"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_dark"
                    android:text="@string/date_all"/>
                <Button
                    android:id="@+id/btnPickDate"
                    style="@style/Btn.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_pick_date"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"/>
                <Button
                    android:id="@+id/btnClearDate"
                    style="@style/Btn.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:text="✕"
                    android:textSize="14sp"
                    android:minWidth="44dp"
                    android:paddingHorizontal="10dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Résumé -->
            <TextView
                android:id="@+id/txtSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="10dp"
                android:background="#F9FAFB"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:text="@string/loading"/>

            <!-- Actions principales -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <Button
                    android:id="@+id/btnRefresh"
                    style="@style/Btn.Outline"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="46dp"
                    android:text="🔄 Actualiser"
                    android:textSize="13sp"/>
                <Button
                    android:id="@+id/btnPdf"
                    style="@style/Btn.Warning"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="46dp"
                    android:layout_marginStart="6dp"
                    android:text="📄 PDF"
                    android:textSize="13sp"/>
                <Button
                    android:id="@+id/btnSync"
                    style="@style/Btn.Success"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="46dp"
                    android:layout_marginStart="6dp"
                    android:text="☁️ Sync"
                    android:textSize="13sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="280dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Boutons sticky en bas -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="10dp"
        android:elevation="12dp">
        <Button
            android:id="@+id/btnPatron"
            style="@style/Btn.Warning"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:text="📓 Mes Comptes"
            android:textSize="13sp"/>
        <Button
            android:id="@+id/btnPoints"
            style="@style/Btn.Purple"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="📊 Mes Points"
            android:textSize="13sp"/>
    </LinearLayout>
</LinearLayout>
