<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:orientation="vertical"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#6A1B9A"
                android:text="📊 MES POINTS"/>
            <Button
                android:id="@+id/btnHistory"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📂 Historique" android:textSize="12sp"
                style="@style/Btn.Purple"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666"
            android:layout_marginTop="2dp"
            android:text="Saisissez vos soldes du jour. Le TOTAL est calculé automatiquement."/>

        <!-- Navigation date -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#F3E5F5"
            android:padding="10dp"
            android:gravity="center_vertical">

            <Button android:id="@+id/btnPrev"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="‹" android:textSize="20sp" android:minWidth="48dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:gravity="center">
                <TextView android:id="@+id/txtDate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="14sp" android:textStyle="bold" android:textColor="#4A148C"/>
                <Button android:id="@+id/btnPickDate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="📅 Changer" android:textSize="11sp"
                    style="?android:attr/borderlessButtonStyle" android:textColor="#6A1B9A"/>
            </LinearLayout>

            <Button android:id="@+id/btnNext"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="20sp" android:minWidth="48dp"/>
        </LinearLayout>

        <!-- Soldes opérateurs -->
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:textSize="13sp" android:textStyle="bold"
            android:textColor="#444" android:text="Soldes opérateurs"/>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="OM" android:textStyle="bold" android:textSize="14sp" android:textColor="#FF6F00"/>
            <EditText android:id="@+id/edtOm" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0"
                android:importantForAutofill="no" android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="MoMo" android:textStyle="bold" android:textSize="14sp" android:textColor="#FBC02D"/>
            <EditText android:id="@+id/edtMomo" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0"
                android:importantForAutofill="no" android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="MOOV" android:textStyle="bold" android:textSize="14sp" android:textColor="#1565C0"/>
            <EditText android:id="@+id/edtMoov" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0"
                android:importantForAutofill="no" android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="WAVE" android:textStyle="bold" android:textSize="14sp" android:textColor="#00ACC1"/>
            <EditText android:id="@+id/edtWave" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0"
                android:importantForAutofill="no" android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="djamo" android:textStyle="bold" android:textSize="14sp" android:textColor="#7B1FA2"/>
            <EditText android:id="@+id/edtDjamo" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0"
                android:importantForAutofill="no" android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="CFA (espèces)" android:textStyle="bold" android:textSize="14sp" android:textColor="#2E7D32"/>
            <EditText android:id="@+id/edtCfa" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0"
                android:importantForAutofill="no" android:textSize="15sp"/>
        </LinearLayout>

        <!-- Mes dépenses -->
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="14dp" android:textSize="13sp" android:textStyle="bold"
            android:textColor="#444" android:text="Mes dépenses"/>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Entrée" android:textStyle="bold" android:textSize="14sp" android:textColor="#2E7D32"/>
            <EditText android:id="@+id/edtEntree" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0"
                android:importantForAutofill="no" android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Sortie" android:textStyle="bold" android:textSize="14sp" android:textColor="#C62828"/>
            <EditText android:id="@+id/edtSortie" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0"
                android:importantForAutofill="no" android:textSize="15sp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/edtNote"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Note du jour (facultatif)"
            android:inputType="text" android:importantForAutofill="no"/>

        <TextView
            android:id="@+id/txtTotal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:padding="14dp"
            android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF"
            android:background="#6A1B9A" android:gravity="center"
            android:text="TOTAL POINTS : 0"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="14dp" android:text="💾 Enregistrer pour ce jour"
            style="@style/Btn.Success"/>
    </LinearLayout>
</ScrollView>
