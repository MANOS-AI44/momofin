<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="@string/title_settings"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            android:text="Réglez ici votre serveur. Le code/token sont gérés automatiquement, vous n'avez pas à les modifier."/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="@string/label_url"/>

        <LinearLayout
            android:id="@+id/advancedZone"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

        <EditText
            android:id="@+id/edtUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_url"
            android:inputType="textUri"
            android:importantForAutofill="no"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="@string/label_token"/>

        <EditText
            android:id="@+id/edtToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_token"
            android:inputType="textPassword"
            android:importantForAutofill="no"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnToggleAdvanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="⚙️ Paramètres avancés (URL serveur)"
            android:textSize="11sp"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#999"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnTest"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/btn_test"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/btn_save_settings"
                style="@style/Btn.Primary"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textSize="13sp"/>


        <View
            android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDD" android:layout_marginVertical="16dp"/>

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:textStyle="bold"
            android:text="📱 Téléphone prioritaire"/>
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="2dp" android:textSize="12sp" android:textColor="#666"
            android:text="Si ACTIVÉ : ce téléphone capte les SMS et les envoie au serveur.\nSi DÉSACTIVÉ : ce téléphone consulte uniquement les transactions/rapports déjà synchronisés depuis votre autre téléphone."/>
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchPrimary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ce téléphone est prioritaire (lit les SMS)"
            android:checked="true"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD"
            android:layout_marginVertical="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#666"
            android:text="@string/reset_help"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="13sp"
            android:textColor="#666"
            android:text="Importer les SMS Mobile Money déjà reçus avant l\'installation de l\'app :"/>

        <Button
            android:id="@+id/btnImportInbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="📥 Importer les SMS de la boîte"
            style="@style/Btn.Warning"/>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/reset_button"
            style="@style/Btn.Danger"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="@color/border"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="↩️  Se deconnecter"
            android:textColor="@color/white"
            android:textStyle="bold"
            style="@style/Btn.Warning"/>

        <TextView
            android:id="@+id/txtCurrentUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:text=""/>

    </LinearLayout>
</ScrollView>
