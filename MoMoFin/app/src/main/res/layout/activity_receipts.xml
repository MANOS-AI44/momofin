<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🧾 Mes Reçus"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary_dark"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:text="Créez un reçu pour un client. Touchez un reçu pour l'imprimer ou le partager."/>

    <Button
        android:id="@+id/btnNewReceipt"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="➕ Nouveau reçu"/>

    <Button
        android:id="@+id/btnRestoreReceipts"
        style="@style/Btn.Outline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="13sp"
        android:text="📥 Restaurer mes reçus (serveur)"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp">
        <LinearLayout
            android:id="@+id/listReceipts"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>
</LinearLayout>
