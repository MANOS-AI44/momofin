<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============ Boutons ============ -->
    <style name="Btn" parent="Widget.AppCompat.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Btn.Primary" parent="Btn">
        <item name="android:background">@drawable/btn_primary</item>
    </style>
    <style name="Btn.Success" parent="Btn">
        <item name="android:background">@drawable/btn_success</item>
    </style>
    <style name="Btn.Danger" parent="Btn">
        <item name="android:background">@drawable/btn_danger</item>
    </style>
    <style name="Btn.Warning" parent="Btn">
        <item name="android:background">@drawable/btn_warning</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="Btn.Purple" parent="Btn">
        <item name="android:background">@drawable/btn_purple</item>
    </style>
    <style name="Btn.Outline" parent="Btn">
        <item name="android:background">@drawable/btn_outline</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- ============ Cartes ============ -->
    <style name="Card">
        <item name="android:background">@drawable/card_white</item>
        <item name="android:padding">16dp</item>
        <item name="android:elevation">1dp</item>
    </style>

    <!-- ============ Titres ============ -->
    <style name="Title" parent="android:Widget.TextView">
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Title.H1" parent="Title">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/primary_dark</item>
    </style>
    <style name="Title.H2" parent="Title">
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="Subtitle" parent="android:Widget.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
