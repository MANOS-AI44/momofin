<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Lecture du ContentProvider de l'app MoMo SMS -->
    <uses-permission android:name="com.gerard.momosms.READ_MOMO" />

    <!-- Fallback : lecture directe des SMS si MoMo SMS n'est pas installé -->
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Synchronisation avec le backend Railway -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Écrire le PDF dans Téléchargements via MediaStore (pas besoin de permission sur API 29+) -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MoMoFin"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".PatronActivity"
            android:exported="false"
            android:label="@string/title_patron"/>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings"/>

        <!-- Provider FileProvider pour partager le PDF généré -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Indique qu'on peut interroger le ContentProvider de MoMo SMS -->
    <queries>
        <package android:name="com.gerard.momosms" />
        <provider android:authorities="com.gerard.momosms.provider" />
    </queries>
</manifest>
