<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- SMS : lecture directe + capture temps réel (ancien Android) -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />

    <!-- Notifications (Android 13+) : afficher + LIRE celles des autres apps (méthode moderne) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- Service en arrière-plan -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Demande d'exemption d'optimisation batterie (Etape 2 du wizard) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Réseau pour synchro Railway -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MoMoFin"
        tools:targetApi="34">

        <activity android:name=".LoginActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".MainActivity" android:exported="false"/>
        <activity android:name=".PointsActivity" android:exported="false"/>
        <activity android:name=".PointsHistoryActivity" android:exported="false"/>
        <activity android:name=".PatronActivity" android:exported="false" android:label="@string/title_patron"/>
        <activity android:name=".FolderDetailActivity" android:exported="false"/>
        <activity android:name=".DevicesActivity" android:exported="false"/>
        <activity android:name=".SettingsActivity" android:exported="false" android:label="@string/title_settings"/>

        <!-- 1) BroadcastReceiver SMS — capte les SMS entrants en temps réel (Android < 13) -->
        <receiver
            android:name=".SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- 2) NotificationListenerService — lit les notifications (Android 13+) -->
        <service
            android:name=".SmsNotificationListener"
            android:label="@string/notif_service_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
            <activity android:name=".TransactionDetailActivity" android:exported="false" android:label="Détail transaction" />
            <activity android:name=".PermissionWizardActivity" android:exported="false" android:label="Activer les SMS" />
    </application>
</manifest>
